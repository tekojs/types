{
  "name": "@tekojs/types",
  "version": "1.0.1",
  "description": "Shared public types for the Teko ecosystem",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "!dist/tests",
    "!dist/**/*.test.*",
    "dist/**/*.d.ts",
    "dist/**/*.js"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tekojs/types.git"
  },
  "homepage": "https://github.com/tekojs/types#readme",
  "bugs": {
    "url": "https://github.com/tekojs/types/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "husky",
    "commitlint": "commitlint --edit",
    "commit": "cz",
    "test": "echo \"Error: no test specified\" && exit 0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "husky": "^9.1.7",
    "prettier": "^3.5.2",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "keywords": [
    "teko",
    "ssr",
    "templates",
    "frontend"
  ],
  "author": "Jefte Costa <jefteamorim@gmail.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "tsdown": {
    "entry": [
      "./index.ts",
      "./src/types.ts"
    ],
    "outDir": "./dist",
    "clean": true,
    "format": "esm",
    "minify": "dce-only",
    "fixedExtension": false,
    "dts": false,
    "treeshake": false,
    "sourcemaps": false,
    "target": "esnext"
  }
}
